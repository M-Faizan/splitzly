{
  "expo": {
    "name": "Splitzly",
    "slug": "splitzly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#162840"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.splitzly.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.splitzly.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#162840"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "template": "./web/index.html"
    },
    "extra": {
      "eas": {
        "projectId": "e97a10c2-e725-4d70-b913-41131834fe44"
      }
    },
    "owner": "fazig117"
  }
}
